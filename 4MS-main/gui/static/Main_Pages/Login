<body class="bg-background-light dark:bg-background-dark min-h-screen flex items-center justify-center p-4">
<!-- Main Container -->
<div class="layout-container flex h-full grow flex-col items-center justify-center w-full max-w-[1200px]">
<!-- Login Card -->
<div class="bg-white dark:bg-[#1a2430] shadow-2xl rounded-xl w-full max-w-[480px] flex flex-col overflow-hidden border border-[#e5e7eb] dark:border-[#2d3a4b]">
<!-- Header Section -->
