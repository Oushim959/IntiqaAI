<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>IntiqAI — Agentic Talent Screening &amp; Interview Platform</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: { primary: "#0ea5e9", navy: "#0f172a" },
          fontFamily: { sans: ["Outfit", "system-ui", "sans-serif"] }
        }
      }
    };
  </script>
  <style>
    .gradient-mesh { background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(14,165,233,.15), transparent), radial-gradient(ellipse 60% 40% at 100% 0%, rgba(14,165,233,.08), transparent); }
    .dark .gradient-mesh { background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(14,165,233,.2), transparent), radial-gradient(ellipse 60% 40% at 100% 0%, rgba(14,165,233,.1), transparent); }
    .pipeline-arrow { stroke-dasharray: 6 4; animation: dash 12s linear infinite; }
    @keyframes dash { to { stroke-dashoffset: -100; } }
    .card-hover { transition: transform .2s ease, box-shadow .2s ease; }
    .card-hover:hover { transform: translateY(-2px); box-shadow: 0 20px 40px -15px rgba(15,23,42,.12); }
    .dark .card-hover:hover { box-shadow: 0 20px 40px -15px rgba(0,0,0,.3); }
  </style>
</head>
<body class="bg-slate-50 dark:bg-slate-900 font-sans text-navy dark:text-slate-100 antialiased min-h-screen flex flex-col transition-colors">
  <header class="sticky top-0 z-50 border-b border-slate-200 dark:border-slate-700 bg-white/95 dark:bg-slate-800/95 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-4 lg:px-10 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <span class="text-xl font-semibold tracking-tight text-navy dark:text-slate-100">IntiqAI</span>
      </a>
      <nav class="flex items-center gap-6">
        <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors" href="#pipeline">Pipeline</a>
        <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors" href="#about">About</a>
        <a class="text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-primary transition-colors" href="#portals">Portals</a>
        <button type="button" id="themeToggle" class="p-2 rounded-lg text-slate-500 dark:text-slate-400 hover:text-navy dark:hover:text-slate-100 transition-colors" title="Toggle dark mode" aria-label="Toggle dark mode">
          <svg id="themeIconSun" class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          <svg id="themeIconMoon" class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
      </nav>
    </div>
  </header>

  <main class="flex-1">
    <section class="gradient-mesh px-4 lg:px-10 pt-20 pb-28 lg:pt-28 lg:pb-36">
      <div class="max-w-5xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-navy dark:text-slate-100 leading-[1.15] tracking-tight mb-6">
          Agentic AI talent screening, <span class="text-primary">end to end</span>
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          From CV analysis and knowledge assessment to structured voice interviews. One platform, one pipeline, full transparency for HR and candidates.
        </p>
        <a href="#portals" class="inline-flex items-center gap-2 px-6 py-3.5 bg-primary text-white font-semibold rounded-xl hover:bg-primary/90 transition-colors shadow-lg shadow-primary/25">
          Enter platform
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>
    </section>

    <section id="pipeline" class="px-4 lg:px-10 py-20 bg-white dark:bg-slate-800/50 border-y border-slate-100 dark:border-slate-700">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl lg:text-4xl font-semibold text-navy dark:text-slate-100 text-center mb-4">How it works</h2>
        <p class="text-slate-600 dark:text-slate-400 text-center max-w-xl mx-auto mb-16">A single, auditable pipeline from application to interview.</p>
        <div class="grid md:grid-cols-3 gap-8 lg:gap-12 items-start">
          <div class="relative card-hover bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8">
            <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-6">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-navy dark:text-slate-100 mb-2">1. CV screening</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Upload JD and resumes. AI scores fit and writes a short justification per candidate. Only high-fit applicants move forward.</p>
          </div>
          <div class="relative card-hover bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8">
            <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-6">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-navy dark:text-slate-100 mb-2">2. Knowledge assessment</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Candidates complete a fundamental knowledge assessment (FKA). Pass threshold required to unlock the voice interview.</p>
          </div>
          <div class="relative card-hover bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8">
            <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-6">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-4a4 4 0 01-.88-7.903A5 5 0 0112 2.05A5 5 0 0116.9 10H19a7 7 0 010 14z"/></svg>
            </div>
            <h3 class="text-xl font-semibold text-navy dark:text-slate-100 mb-2">3. Voice interview</h3>
            <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">Structured AI interview by voice: listen to questions, answer with your microphone. Evaluation and report generated at the end.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="px-4 lg:px-10 py-20 bg-slate-50/80 dark:bg-slate-900/80">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl lg:text-4xl font-semibold text-navy dark:text-slate-100 text-center mb-4">About the project</h2>
        <p class="text-slate-600 dark:text-slate-400 text-center max-w-2xl mx-auto mb-12 leading-relaxed">
          IntiqAI is an end-to-end talent screening platform that combines CV filtering, knowledge assessments, and AI-driven voice interviews. Built for fairness, speed, and transparency: HR sees justifications at every stage; candidates get a clear, step-by-step journey.
        </p>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6">
            <h4 class="font-semibold text-navy dark:text-slate-100 mb-2">For HR</h4>
            <p class="text-slate-600 dark:text-slate-400 text-sm">Manage runs, assign credentials, track status, and review CV justifications and FKA results in one dashboard.</p>
          </div>
          <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6">
            <h4 class="font-semibold text-navy dark:text-slate-100 mb-2">For candidates</h4>
            <p class="text-slate-600 dark:text-slate-400 text-sm">One portal: complete the knowledge assessment, then the voice interview. Clear steps and results.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="portals" class="px-4 lg:px-10 py-20 bg-white dark:bg-slate-800/50 border-t border-slate-100 dark:border-slate-700">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl lg:text-4xl font-semibold text-navy dark:text-slate-100 text-center mb-4">Choose your portal</h2>
        <p class="text-slate-600 dark:text-slate-400 text-center mb-12">Sign in to manage pipelines or continue your candidate journey.</p>
        <div class="grid md:grid-cols-2 gap-8">
          <a href="/hr/login" class="group block p-8 rounded-2xl bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 hover:border-primary/50 card-hover">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              </div>
              <h3 class="text-xl font-semibold text-navy dark:text-slate-100">HR Portal</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-400 text-sm mb-6">Upload JDs and CVs, assign credentials, and track every candidate with justifications and stats.</p>
            <span class="text-primary font-semibold text-sm inline-flex items-center gap-1">Sign in as HR <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </a>
          <a href="/candidate/login" class="group block p-8 rounded-2xl bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 hover:border-primary/50 card-hover">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary/20 transition-colors">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <h3 class="text-xl font-semibold text-navy dark:text-slate-100">Candidate Portal</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-400 text-sm mb-6">Use the email and password from HR to access your knowledge assessment and voice interview.</p>
            <span class="text-primary font-semibold text-sm inline-flex items-center gap-1">Sign in as candidate <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 py-8">
    <div class="max-w-6xl mx-auto px-4 lg:px-10 text-center text-sm text-slate-500 dark:text-slate-400">
      © IntiqAI — Equitable, rigorous, end-to-end talent screening.
    </div>
  </footer>
  <script>
    (function themeInit() {
      var stored = localStorage.getItem("theme");
      var dark = stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches);
      if (dark) document.documentElement.classList.add("dark"); else document.documentElement.classList.remove("dark");
      var btn = document.getElementById("themeToggle");
      if (btn) btn.addEventListener("click", function() {
        document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
      });
    })();
  </script>
</body>
</html>
