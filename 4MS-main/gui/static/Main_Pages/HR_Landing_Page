<script>
// Simple client-side navigation for HR flows
(function () {
  const uploadBtn = document.getElementById("hrUploadBtn");
  const ingestionLink = document.getElementById("hrIngestionLink");

  function goToUpload() {
    const isLocal =
      window.location.origin.includes("localhost") ||
      window.location.origin.includes("127.0.0.1");
    if (isLocal) {
      window.location.href = "/hr/cv_upload";
    } else {
      window.location.href = "../CV_Filtering/UPLOAD";
    }
  }

  if (uploadBtn) {
    uploadBtn.addEventListener("click", function (e) {
      e.preventDefault();
      goToUpload();
    });
  }

  // Candidate Ingestion link should open the CV Filtering dashboard
  if (ingestionLink) {
    ingestionLink.addEventListener("click", function (e) {
      e.preventDefault();
      const isLocal =
        window.location.origin.includes("localhost") ||
        window.location.origin.includes("127.0.0.1");
      if (isLocal) {
        window.location.href = "/hr/cv_filtering";
      } else {
        window.location.href = "../CV_Filtering/CV_Dashboard";
      }
    });
  }
})();
</script>
