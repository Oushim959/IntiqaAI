<script>
    // Comprehensive CV Filtering Dashboard with auto-refresh and file upload
    (function () {
      let refreshInterval = null;
      let isFiltering = false;
      let lastUpdateTimestamp = null;

      // Always run (API is same origin when served from this app). No host check.

      // Format timestamp for display
      function formatTimeAgo(timestamp) {
        if (!timestamp) return "Never";
        const date = new Date(timestamp);
        const now = new Date();
        const diffMs = now - date;
        const diffMins = Math.floor(diffMs / 60000);
        if (diffMins < 1) return "Just now";
        if (diffMins < 60) return `${diffMins} minute${diffMins > 1 ? "s" : ""} ago`;
        const diffHours = Math.floor(diffMins / 60);
        if (diffHours < 24) return `${diffHours} hour${diffHours > 1 ? "s" : ""} ago`;
        const diffDays = Math.floor(diffHours / 24);
        return `${diffDays} day${diffDays > 1 ? "s" : ""} ago`;
      }

      // Update last update time display
      function updateLastUpdateTime(timestamp) {
        const timeEl = document.getElementById("lastUpdateTime");
        if (timeEl) {
          timeEl.textContent = `Last update: ${formatTimeAgo(timestamp)}`;
          lastUpdateTimestamp = timestamp;
        }
      }

      // Show/hide refresh indicator
      function setRefreshing(isRefreshing) {
        const indicator = document.getElementById("refreshIndicator");
        if (indicator) {
          if (isRefreshing) {
            indicator.classList.remove("hidden");
          } else {
            indicator.classList.add("hidden");
          }
        }
      }

      // Load dashboard data
      async function loadDashboard(showIndicator = false) {
        if (showIndicator) setRefreshing(true);

        try {
          const cacheBust = "?_t=" + Date.now();
          const metaResp = await fetch("/api/cv_filter/latest" + cacheBust);
          if (metaResp.ok) {
            const meta = await metaResp.json();
            const countEl = document.getElementById("validatedCount");
            if (countEl && meta.total_resumes != null) {
              countEl.textContent = String(meta.total_resumes);
            }
            const jdTitle = document.getElementById("jdPreviewTitle");
            if (jdTitle && meta.jd_title) {
              jdTitle.textContent = 'JD Preview: "' + meta.jd_title + '"';
            }
            const jdBody = document.getElementById("jdPreviewBody");
            if (jdBody && meta.jd_preview) {
              jdBody.textContent = meta.jd_preview;
            }
            if (meta.timestamp) {
              updateLastUpdateTime(meta.timestamp);
            }

            // Update download buttons
            const exportContainer = document.getElementById("exportButtonsContainer");
            if (exportContainer) {
              if (meta.total_resumes > 0) {
                exportContainer.classList.remove("hidden");
                // Update hrefs just in case, though they are static
              } else {
                exportContainer.classList.add("hidden");
              }
            }
          } else if (metaResp.status === 404) {
            const countEl = document.getElementById("validatedCount");
            if (countEl) countEl.textContent = "0";
            updateLastUpdateTime(null);
          } else {
            const countEl = document.getElementById("validatedCount");
            if (countEl) countEl.textContent = "—";
            var lastEl = document.getElementById("lastUpdateTime");
            if (lastEl) lastEl.textContent = "Unable to load (check server)";
          }
        } catch (e) {
          console.error("Failed to load latest CV run metadata", e);
          var t = document.getElementById("lastUpdateTime");
          if (t) t.textContent = "Connection error: " + e.message;
        }

        try {
          const cacheBust = "&_t=" + Date.now();
          const candResp = await fetch("/api/cv_filter/candidates?limit=5" + cacheBust);
          if (candResp.ok) {
            const data = await candResp.json();
            const list = document.getElementById("candidateList");
            const statusEl = document.getElementById("candidateApiStatus");
            if (statusEl) statusEl.textContent = "Candidates loaded: " + (data.candidates ? data.candidates.length : 0);
            if (list) {
              if (data.candidates && data.candidates.length > 0) {
                list.innerHTML = "";
                data.candidates.forEach(function (c) {
                  const li = document.createElement("li");
                  const name =
                    ((c["First Name"] || "") + " " + (c["Last Name"] || "")).trim() ||
                    "Unnamed";
                  const score =
                    c["Overall Fit"] !== undefined && c["Overall Fit"] !== null
                      ? String(c["Overall Fit"])
                      : "N/A";
                  li.className =
                    "flex items-center justify-between text-xs text-slate-600 dark:text-slate-300 py-1";
                  li.innerHTML =
                    '<span class="font-medium">' +
                    name +
                    "</span><span class=\"font-semibold text-primary\">" +
                    score +
                    "</span>";
                  list.appendChild(li);
                });
              } else {
                list.innerHTML = '<li class="italic text-slate-400">No candidates found. Run filtering to see results.</li>';
              }
            }
          } else if (candResp.status === 404) {
            const list = document.getElementById("candidateList");
            const statusEl = document.getElementById("candidateApiStatus");
            if (statusEl) statusEl.textContent = "No run yet";
            if (list) {
              list.innerHTML = '<li class="italic text-slate-400">Run a CV filtering session to see candidates here.</li>';
            }
          } else {
            const list = document.getElementById("candidateList");
            const statusEl = document.getElementById("candidateApiStatus");
            if (statusEl) statusEl.textContent = "Error " + candResp.status + " — refresh or restart server";
            if (list) list.innerHTML = '<li class="italic text-amber-600">Could not load candidates (server error). Restart the app with: python run_all.py from 4MS-main folder, then refresh.</li>';
          }
        } catch (e) {
          console.error("Failed to load candidate list", e);
          var statusEl = document.getElementById("candidateApiStatus");
          if (statusEl) statusEl.textContent = "Connection error";
        }

        if (showIndicator) setRefreshing(false);
      }

      // Run CV filtering with uploaded files (exposed globally for onclick fallback)
      async function runFiltering() {
        if (isFiltering) return;

        const jdFileInput = document.getElementById("jdFileInput");
        const cvFilesInput = document.getElementById("cvFilesInput");
        const btn = document.getElementById("initializeFilteringBtn");
        const btnText = document.getElementById("filteringBtnText");
        const btnIcon = document.getElementById("filteringBtnIcon");

        if (!jdFileInput || !cvFilesInput) {
          alert("File inputs not available. Please refresh the page.");
          return;
        }

        const jdFile = jdFileInput.files && jdFileInput.files[0];
        const cvFiles = Array.from(cvFilesInput.files || []).filter((f) =>
          f.name.toLowerCase().endsWith(".pdf")
        );

        if (!jdFile) {
          alert("Please upload a Job Description (JD) file.");
          return;
        }

        if (!cvFiles.length) {
          alert("Please upload at least one CV PDF file.");
          return;
        }

        isFiltering = true;
        if (btn) btn.disabled = true;
        if (btnText) btnText.textContent = "Processing...";
        if (btnIcon) btnIcon.textContent = "hourglass_empty";

        try {
          const formData = new FormData();
          cvFiles.forEach((file) => formData.append("cvs", file));
          formData.append("jd", jdFile);

          const resp = await fetch("/api/cv_filter/upload-run", {
            method: "POST",
            body: formData,
          });

          var data;
          try {
            data = await resp.json();
          } catch (_) {
            throw new Error("Server error (status " + resp.status + "). Check server logs.");
          }
          if (!resp.ok) {
            var msg = (data && data.detail) ? (typeof data.detail === "string" ? data.detail : JSON.stringify(data.detail)) : "CV filtering failed";
            if (resp.status === 429) {
              msg = "Rate limit exceeded (Groq). Try again in a few minutes or upload fewer CVs at once.";
            }
            throw new Error(msg);
          }

          // Success - reload dashboard immediately (force fresh data, no cache)
          await loadDashboard(true);

          // Show success message
          alert(`✅ CV filtering completed successfully!\n\nProcessed ${data.total_resumes} resume(s).\nResults are now available in the dashboard.`);

        } catch (err) {
          console.error("Filtering error:", err);
          alert("❌ Error running CV filtering: " + err.message);
        } finally {
          isFiltering = false;
          if (btn) btn.disabled = false;
          if (btnText) btnText.textContent = "Initialize Filtering";
          if (btnIcon) btnIcon.textContent = "rocket_launch";
        }
      }

      // Setup file input handlers with drag-and-drop
      function setupFileHandlers() {
        const jdFileInput = document.getElementById("jdFileInput");
        const cvFilesInput = document.getElementById("cvFilesInput");
        const jdFileName = document.getElementById("jdFileName");
        const cvFilesCount = document.getElementById("cvFilesCount");
        const jdUploadZone = document.getElementById("jdUploadZone");
        const cvUploadZone = document.getElementById("cvUploadZone");
        const jdUploadStatus = document.getElementById("jdUploadStatus");
        const cvUploadStatus = document.getElementById("cvUploadStatus");

        // JD file handler
        if (jdFileInput && jdFileName && jdUploadZone) {
          jdFileInput.addEventListener("change", function () {
            const file = jdFileInput.files && jdFileInput.files[0];
            if (file) {
              jdFileName.textContent = file.name;
              if (jdUploadStatus) {
                jdUploadStatus.classList.remove("hidden");
                jdUploadStatus.textContent = `✓ ${file.name} ready`;
              }
            } else {
              jdFileName.textContent = "Click to upload or drag and drop (PDF, DOCX)";
              if (jdUploadStatus) jdUploadStatus.classList.add("hidden");
            }
          });

          // Drag and drop for JD
          jdUploadZone.addEventListener("dragover", function (e) {
            e.preventDefault();
            jdUploadZone.classList.add("border-primary", "bg-primary/10");
          });
          jdUploadZone.addEventListener("dragleave", function (e) {
            e.preventDefault();
            jdUploadZone.classList.remove("border-primary", "bg-primary/10");
          });
          jdUploadZone.addEventListener("drop", function (e) {
            e.preventDefault();
            jdUploadZone.classList.remove("border-primary", "bg-primary/10");
            const files = e.dataTransfer.files;
            if (files.length > 0 && (files[0].name.endsWith(".pdf") || files[0].name.endsWith(".docx"))) {
              jdFileInput.files = files;
              jdFileInput.dispatchEvent(new Event("change"));
            }
          });
        }

        // CV files handler
        if (cvFilesInput && cvFilesCount && cvUploadZone) {
          cvFilesInput.addEventListener("change", function () {
            const files = Array.from(cvFilesInput.files || []).filter((f) =>
              f.name.toLowerCase().endsWith(".pdf")
            );
            if (files.length > 0) {
              cvFilesCount.textContent = `${files.length} PDF file${files.length > 1 ? "s" : ""} selected`;
              if (cvUploadStatus) {
                cvUploadStatus.classList.remove("hidden");
                cvUploadStatus.textContent = `✓ ${files.length} file${files.length > 1 ? "s" : ""} ready`;
              }
            } else {
              cvFilesCount.textContent = "Click to select CV PDF files";
              if (cvUploadStatus) cvUploadStatus.classList.add("hidden");
            }
          });

          // Drag and drop for CVs
          cvUploadZone.addEventListener("dragover", function (e) {
            e.preventDefault();
            cvUploadZone.classList.add("border-primary", "bg-primary/10");
          });
          cvUploadZone.addEventListener("dragleave", function (e) {
            e.preventDefault();
            cvUploadZone.classList.remove("border-primary", "bg-primary/10");
          });
          cvUploadZone.addEventListener("drop", function (e) {
            e.preventDefault();
            cvUploadZone.classList.remove("border-primary", "bg-primary/10");
            const files = Array.from(e.dataTransfer.files).filter((f) =>
              f.name.toLowerCase().endsWith(".pdf")
            );
            if (files.length > 0) {
              const dt = new DataTransfer();
              files.forEach((f) => dt.items.add(f));
              cvFilesInput.files = dt.files;
              cvFilesInput.dispatchEvent(new Event("change"));
            }
          });
        }

        // Initialize Filtering button
        const initBtn = document.getElementById("initializeFilteringBtn");
        if (initBtn) {
          initBtn.addEventListener("click", runFiltering);
        }
      }

      // Start auto-refresh
      function startAutoRefresh() {
        if (refreshInterval) clearInterval(refreshInterval);
        // Refresh every 5 seconds
        refreshInterval = setInterval(loadDashboard, 5000);
      }

      // Manual refresh handler
      function setupRefreshButton() {
        const refreshBtn = document.getElementById("refreshBtn");
        if (refreshBtn) {
          refreshBtn.addEventListener("click", function () {
            loadDashboard(true);
          });
        }
      }

      // Expose runFiltering globally so button works even if listener fails
      window.runFiltering = runFiltering;

      // Initialize on page load
      document.addEventListener("DOMContentLoaded", function () {
        loadDashboard();
        setupFileHandlers();
        setupRefreshButton();
        startAutoRefresh();
        var status = document.getElementById("lastUpdateTime");
        if (status && status.textContent === "Loading...") status.textContent = "No data yet — upload files and click Initialize Filtering";
      });

      // Cleanup on page unload
      window.addEventListener("beforeunload", function () {
        if (refreshInterval) clearInterval(refreshInterval);
      });
    })();
</script>

</html>