                                            </li>
<li class="flex items-start gap-3 text-sm text-[#617289] dark:text-gray-400">
<span class="material-symbols-outlined text-primary text-lg">check_circle</span>
                                                Use a desktop browser for the best experience.
                                            </li>
<li class="flex items-start gap-3 text-sm text-[#617289] dark:text-gray-400">
<span class="material-symbols-outlined text-primary text-lg">check_circle</span>
                                                Find a quiet environment to focus.
                                            </li>
</ul>
</div>
<!-- Action / Upload Form -->
<form id="assessment-form" class="flex flex-col gap-4 pt-4">
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
  <div class="flex flex-col gap-1">
    <label for="jd-file" class="text-xs font-semibold uppercase tracking-wide text-[#111418] dark:text-white">
      Job Description (PDF / DOCX / TXT)
    </label>
    <input id="jd-file" name="jd_file" type="file" accept=".pdf,.docx,.txt" class="block w-full text-xs text-[#617289] dark:text-gray-300 file:mr-3 file:rounded-md file:border-0 file:bg-primary/10 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-primary hover:file:bg-primary/20"/>
  </div>
  <div class="flex flex-col gap-1">
    <label for="cv-file" class="text-xs font-semibold uppercase tracking-wide text-[#111418] dark:text-white">
      Candidate CV / Resume (optional)
    </label>
    <input id="cv-file" name="cv_file" type="file" accept=".pdf,.docx,.txt" class="block w-full text-xs text-[#617289] dark:text-gray-300 file:mr-3 file:rounded-md file:border-0 file:bg-primary/10 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-primary hover:file:bg-primary/20"/>
  </div>
</div>
<button id="start-assessment-btn" type="submit" class="flex w-full cursor-pointer items-center justify-center rounded-lg h-14 bg-primary hover:bg-primary/90 transition-colors text-white gap-3 text-lg font-bold">
<span class="material-symbols-outlined">play_arrow</span>
<span>Start Assessment</span>
</button>
<p class="text-center text-xs text-[#617289] dark:text-gray-500 italic">
                                            "Upload the JD to generate tailored questions. This assessment is untimed; focus on high-quality responses."
                                        </p>
</form>
</div>
</div>
</div>
</div>
<!-- Footer / Support -->
<footer class="flex flex-col items-center gap-4 py-8">
<div class="flex gap-6 text-sm font-medium text-[#617289] dark:text-gray-500">
<a class="hover:text-primary transition-colors" href="#">Technical Support</a>
<span class="text-gray-300 dark:text-gray-700">|</span>
<a class="hover:text-primary transition-colors" href="#">Candidate FAQs</a>
</div>
<p class="text-xs text-gray-400 dark:text-gray-600">
                            © 2023 IntiqAI Assessment Portal. All rights reserved.
                        </p>
</footer>
</div>
</main>
</div>
</div>
<script>
  (function() {
    const form = document.getElementById("assessment-form");
    const startBtn = document.getElementById("start-assessment-btn");
    const jdInput = document.getElementById("jd-file");
    const cvInput = document.getElementById("cv-file");

    if (form && startBtn) {
      form.addEventListener("submit", function(event) {
        event.preventDefault();

        if (!jdInput.files || jdInput.files.length === 0) {
          alert("Please upload a Job Description file to start the assessment.");
          return;
        }

        startBtn.disabled = true;
        startBtn.textContent = "Preparing assessment...";

        const formData = new FormData();
        formData.append("jd_file", jdInput.files[0]);

        if (cvInput.files && cvInput.files.length > 0) {
          formData.append("cv_file", cvInput.files[0]);
        }

        fetch("/api/init_from_upload", {
          method: "POST",
          body: formData,
        })
          .then(function(res) {
            if (!res.ok) {
              throw new Error("Failed to initialize assessment from uploaded JD.");
            }
            return res.json();
          })
          .then(function(data) {
            if (!data.session_id) {
              throw new Error("No session ID returned from server.");
            }
            window.location.href = "/assessment?session_id=" + encodeURIComponent(data.session_id);
          })
          .catch(function(err) {
            console.error(err);
            alert("There was an error starting the assessment. Please try again.");
            startBtn.disabled = false;
            startBtn.textContent = "Start Assessment";
          });
      });
    }
  })();
</script>
</body></html>