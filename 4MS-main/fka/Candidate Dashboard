<main class="flex flex-1 flex-col items-center justify-center p-6 sm:p-10">
<div class="layout-content-container flex flex-col max-w-[800px] w-full gap-8">
<!-- Welcome Text -->
<div class="flex flex-col items-center text-center gap-2">
<h1 class="text-[#111418] dark:text-white tracking-tight text-4xl font-extrabold leading-tight">Welcome, Alex</h1>
<p class="text-[#617289] dark:text-gray-400 text-lg max-w-lg">
                            We're excited to see your skills in action. You've been invited to complete the first phase of the technical interview process.
                        </p>
</div>
<!-- Main Assessment Card -->
<div class="bg-white dark:bg-gray-900 rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100 dark:border-gray-800 overflow-hidden">
<div class="flex flex-col @container">
<div class="flex flex-col md:flex-row">
<!-- Banner Image -->
<div class="w-full md:w-1/3 min-h-[200px] bg-center bg-no-repeat bg-cover" data-alt="Clean abstract digital pattern in soft blue and white" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCc7UqFkEwBC4HGU09yglH371_LencnPUnwwN79b-vKgzgZ0zQRXpK9HpV8PvtV8k5L2wAGpSh9o_7I3QVIh68BEVp3lhwha1jicoh70e2mV6_-pOxQImhVTiOH_zjN4EJ-iEqydQxGWizQBZ1w47wicF2FgzzIYmzfkiC_lKshDy5knm880z-pGLZat_b11nnBl8yd4X_Vjb8IJQRpLgkNT-aIP1ZBRt4hhDXbmk4957_JYSr3gR10vnuCapqtLa8qJO6rCkQB3ck");'>
</div>
<!-- Card Content -->
<div class="flex flex-col flex-1 p-8 gap-6">
<div class="flex flex-col gap-2">
<div class="inline-flex items-center px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider w-fit">
                                            Stage 1: Assessment
                                        </div>
<h2 class="text-[#111418] dark:text-white text-2xl font-bold">Fundamental Knowledge Assessment (FKA)</h2>
<p class="text-[#617289] dark:text-gray-400 text-base leading-relaxed">
                                            This assessment evaluates core technical concepts, analytical reasoning, and problem-solving skills tailored for the Engineering Specialist role.
                                        </p>
</div>
<!-- Quick Info (no duration/deadline) -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
<div class="flex flex-col gap-1 p-4 rounded-lg border border-gray-100 dark:border-gray-800 bg-background-light/50 dark:bg-gray-800/30">
<div class="flex items-center gap-2 text-primary">
<span class="material-symbols-outlined text-sm">psychology</span>
<p class="text-xs font-semibold uppercase tracking-wide">Assessment Focus</p>
</div>
<p class="text-[#111418] dark:text-white font-bold text-lg">Core concepts & reasoning</p>
</div>
<div class="flex flex-col gap-1 p-4 rounded-lg border border-gray-100 dark:border-gray-800 bg-background-light/50 dark:bg-gray-800/30">
<div class="flex items-center gap-2 text-primary">
<span class="material-symbols-outlined text-sm">fact_check</span>
<p class="text-xs font-semibold uppercase tracking-wide">Format</p>
</div>
<p class="text-[#111418] dark:text-white font-bold text-lg">Short written responses</p>
</div>
</div>
<!-- Checklist/Requirements -->
<div class="flex flex-col gap-3 pt-2">
<p class="text-sm font-bold text-[#111418] dark:text-white uppercase tracking-wider">Before you begin:</p>
<ul class="flex flex-col gap-2">
<li class="flex items-start gap-3 text-sm text-[#617289] dark:text-gray-400">
<span class="material-symbols-outlined text-primary text-lg">check_circle</span>
